        "leg1": { "rotation": ["Math.cos(query.anim_time * 38.17) * -40", 0, 0] },
        "leg2": { "rotation": ["Math.cos(query.anim_time * 38.17) * -40", 0, 0] },
        "leg3": { "rotation": ["Math.cos(query.anim_time * 38.17) * 40", 0, 0] }
      }
    }
  }
}